# ──────────────────────────────────────────────
# Lumora AI — Required Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local for local dev, or
# paste the values into Vercel → Project Settings → Environment Variables

# ── Database ──
# Neon PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@ep-xxxx.aws.neon.tech/neondb?sslmode=require"

# ── Better Auth ──
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="paste-64-char-hex-here"
# Production URL (no trailing slash)
BETTER_AUTH_URL="https://your-project.vercel.app"

# ── Email (Resend) — required for OTP verification ──
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Optional: custom from-address (default: "Lumora <verify@lumora.ai>")
RESEND_FROM_EMAIL="Lumora <verify@lumora.ai>"

# ── AI (Google Gemini) — required for analysis features ──
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional model overrides (defaults: gemini-2.0-flash, gemini-2.0-flash-lite):
# GEMINI_MODEL="gemini-2.0-flash"
# GEMINI_MODEL_FAST="gemini-2.0-flash-lite"

# ── Social Login (optional) ──
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# YAHOO_CLIENT_ID=""
# YAHOO_CLIENT_SECRET=""

# Create at https://developer.apple.com/account/resources/identifiers
# APPLE_CLIENT_ID="com.example"
# APPLE_CLIENT_SECRET=""
# APPLE_APP_BUNDLE_IDENTIFIER=""
